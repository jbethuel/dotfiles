      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(dotnet nuget push:*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.local.json)",
      "Read(./**/secrets/**)",
      "Read(./**/id_rsa)",
      "Read(./**/*.pem)"
    ]
  }
}
